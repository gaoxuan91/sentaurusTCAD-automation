# Sentaurus TCAD VM Configuration
# Copy this file to .env and fill in your values

# VM Connection
TCAD_VM_IP=YOUR_VM_IP
TCAD_VM_USER=your_username
TCAD_VM_PASSWORD=your_password_here
# Or use SSH key:
# TCAD_VM_KEY_PATH=~/.ssh/id_rsa

# Sentaurus Installation (on VM)
SENTAURUS_VERSION=W-2024.09-SP1
SENTAURUS_BIN=/usr/synopsys/sentaurus/W-2024.09-SP1/bin
SENTAURUS_SETUP=/usr/synopsys/sentaurus/W-2024.09-SP1/setup.sh

# VM Project Path
TCAD_VM_PROJECT_PATH=/home/your_user/tcad_project/

# Host Project Path (current directory by default)
# HOST_PROJECT_PATH=./

# Scheduler
SCHEDULER_PORT=8899
SCHEDULER_WORKERS=3
